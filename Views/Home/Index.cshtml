@model IEnumerable<filmdiziarsivi.Models.Movie>
@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-md-6">
        <div class="premium-card h-100">
            <h5 class="mb-3"><i class="bi bi-star-fill text-warning me-2"></i> En Yüksek Puanlılar</h5>
            <canvas id="topRatedChart"></canvas>
        </div>
    </div>
    <div class="col-md-6">
        <div class="premium-card h-100">
            <h5 class="mb-3"><i class="bi bi-eye-fill text-info me-2"></i> En Çok İzlenenler</h5>
            <canvas id="mostWatchedChart"></canvas>
        </div>
    </div>
</div>

<div class="premium-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="m-0"><i class="bi bi-collection-play me-2"></i> Film & Dizi Listesi</h4>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Başlık</th>
                    <th>Tür</th>
                    <th>Yıl</th>
                    <th>Puan</th>
                    <th>İzlenme</th>
                    <th class="text-end">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var movie in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@movie.Title</td>
                            <td><span class="badge bg-secondary">@(movie.Genre?.Name ?? "-")</span></td>
                            <td>@movie.ReleaseYear</td>
                            <td><i class="bi bi-star-fill text-warning small align-text-top"></i> @movie.Rating</td>
                            <td>@movie.Views</td>
                            <td class="text-end">
                                <button type="button" class="btn btn-sm btn-indigo btn-trailer" data-url="@movie.TrailerUrl" aria-label="Fragman İzle: @movie.Title">
                                    <i class="bi bi-play-circle me-1"></i> Fragman
                                </button>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">Sistemde henüz film veya dizi bulunmamaktadır.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            let topRatedChartInstance = null;
            let mostWatchedChartInstance = null;

            async function initCharts() {
                try {
                    const response = await fetch('@Url.Action("GetChartData", "Home")');
                    if (!response.ok) return;
                    const data = await response.json();
                    
                    renderCharts(data);

                    // Re-render when theme changes to update CSS variable colors
                    window.addEventListener('themeChanged', () => {
                        if(topRatedChartInstance) topRatedChartInstance.destroy();
                        if(mostWatchedChartInstance) mostWatchedChartInstance.destroy();
                        renderCharts(data);
                    });

                } catch (err) {
                    console.error("Dashboard veri yüklenemedi", err);
                }
            }

            function renderCharts(data) {
                const style = getComputedStyle(document.body);
                const chartColor1 = style.getPropertyValue('--chart-color-1').trim();
                const chartColor1Border = style.getPropertyValue('--chart-color-1-border').trim();
                const chartColor2 = style.getPropertyValue('--chart-color-2').trim();
                const chartColor2Border = style.getPropertyValue('--chart-color-2-border').trim();
                const textColor = style.getPropertyValue('--text-primary').trim();
                const gridColor = style.getPropertyValue('--border-color').trim();

                const commonOptions = {
                    responsive: true,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: { ticks: { color: textColor }, grid: { color: gridColor } },
                        y: { ticks: { color: textColor }, grid: { color: gridColor }, beginAtZero: true }
                    }
                };

                const ctx1 = document.getElementById('topRatedChart').getContext('2d');
                topRatedChartInstance = new Chart(ctx1, {
                    type: 'bar',
                    data: {
                        labels: data.topRated.labels,
                        datasets: [{
                            data: data.topRated.data,
                            backgroundColor: chartColor1,
                            borderColor: chartColor1Border,
                            borderWidth: 1,
                            borderRadius: 6
                        }]
                    },
                    options: commonOptions
                });

                const ctx2 = document.getElementById('mostWatchedChart').getContext('2d');
                mostWatchedChartInstance = new Chart(ctx2, {
                    type: 'line',
                    data: {
                        labels: data.mostWatched.labels,
                        datasets: [{
                            data: data.mostWatched.data,
                            backgroundColor: chartColor2Border, // For line chart points
                            borderColor: chartColor2Border,
                            borderWidth: 2,
                            tension: 0.3,
                            fill: true,
                            backgroundColor: chartColor2 // fill color
                        }]
                    },
                    options: commonOptions
                });
            }

            initCharts();
        });
    </script>
}
