<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Film Dizi Arşivi</title>
    
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-card border-bottom mb-4 p-3 shadow-sm" style="background-color: var(--bg-card);">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center gap-2" asp-area="" asp-controller="Home" asp-action="Index" style="color: var(--text-primary);">
                    <i class="bi bi-film text-primary"></i> <span style="background: linear-gradient(45deg, var(--accent-color), #2dd4bf); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">ArşivX</span>
                </a>
                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-toggle="target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
                    <ul class="navbar-nav align-items-center gap-3">
                        <li class="nav-item">
                            <a class="btn btn-outline-success btn-sm d-flex align-items-center gap-2" asp-controller="Home" asp-action="ExportExcel">
                                <i class="bi bi-file-earmark-excel"></i> Excel Çıktısı
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-outline-danger btn-sm d-flex align-items-center gap-2" asp-controller="Home" asp-action="ExportPdf">
                                <i class="bi bi-file-earmark-pdf"></i> PDF Çıktısı
                            </a>
                        </li>
                        <li class="nav-item ms-2">
                            <button id="theme-toggle" class="btn btn-sm btn-outline-secondary rounded-pill px-3 shadow-sm">
                                <i class="bi bi-moon-fill"></i> Dark Mode
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top text-muted mt-5 py-4 text-center">
        <div class="container">
            &copy; 2026 - Film ve Dizi Arşivi - Antigravity Architectural Implementations
        </div>
    </footer>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmxc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
